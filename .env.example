# Venture Court — Environment Variables
# Copy this file to .env.local and fill in values as needed.
# The app runs fully in demo mode with no keys set.

# ── Demo mode (default) ──────────────────────────────────────────────
# Set to "true" to force demo fixtures even when API keys are present.
# FORCE_DEMO_MODE=true

# ── CLoD (stretch — live LLM councils + SWE) ────────────────────────
# OpenAI-compatible API at https://api.clod.io/v1
# CLOD_API_KEY=
# CLOD_MODEL_BUILD=claude-3-5-sonnet-20241022
# CLOD_MODEL_REVIEW=claude-3-5-sonnet-20241022

# ── Nia (stretch — live market research) ─────────────────────────────
# REST API at https://apigcp.trynia.ai/v2
# NIA_API_KEY=
